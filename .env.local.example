# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Perplexity API
PERPLEXITY_API_KEY=your_perplexity_api_key

# Naver Search Ad API
NAVER_API_LICENSE_KEY=your_naver_license_key
NAVER_API_SECRET_KEY=your_naver_secret_key
NAVER_API_CUSTOMER_ID=your_naver_customer_id

# Meta (Instagram / Threads)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# YouTube
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Meta Pixel
META_PIXEL_ID=your_pixel_id
META_PIXEL_ACCESS_TOKEN=your_pixel_access_token

# GA4 (서비스 계정)
GA4_PROPERTY_ID=your_ga4_property_id
GA4_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-bucket.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket.r2.dev
